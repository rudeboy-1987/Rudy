# Backend Environment Variables
# Copy this file to .env and fill in the values before running the server.

# ─── Required ────────────────────────────────────────────────────────────────

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017

# MongoDB database name
DB_NAME=electrical_estimator

# Secret key used to sign JWT tokens – use a long, random string in production
# Must be at least 64 characters. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Example format: a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2
JWT_SECRET=

# ─── Optional – Payments (Stripe) ────────────────────────────────────────────

# Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=

# ─── Optional – Email (SendGrid) ─────────────────────────────────────────────

# SendGrid API key
SENDGRID_API_KEY=

# Email address used as the "from" address for outgoing emails
FROM_EMAIL=noreply@rudyelectrical.com

# ─── Optional – AI features ──────────────────────────────────────────────────

# OpenAI or compatible LLM API key used for blueprint analysis
OPENAI_API_KEY=
